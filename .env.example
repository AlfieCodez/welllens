# ---- Flask ----
# Generate a strong value, e.g.  py -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string
FLASK_DEBUG=1

# ---- Database ----
# Defaults to a SQLite file in instance/welllens.db if unset.
# DATABASE_URL=sqlite:///welllens.db

# ---- Uploads ----
# Max upload size in megabytes (per file).
MAX_UPLOAD_MB=25

# ---- Groq (AI narration) ----
# Free tier key from https://console.groq.com/keys
# If unset or the call fails, WellLens falls back to a plain-text template.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Google OAuth (user sign-in + admin) ----
# From https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated list of emails allowed admin access (server-enforced allowlist).
ADMIN_EMAILS=you@example.com

# ---- Garmin Connect (Phase 2) — OAuth 2.0 PKCE ----
# From the Garmin Connect Developer Program (currently on hold for new sign-ups).
# Leave blank to keep Garmin sync disabled; upload still works.
GARMIN_CLIENT_ID=
GARMIN_CLIENT_SECRET=
# Optional: must match the redirect URI registered with Garmin. If blank, it's
# built from the request host (use your public HTTPS domain in production).
GARMIN_REDIRECT_URI=
# Optional OAuth scope (usually leave blank — permissions are set per-app).
GARMIN_SCOPE=
# Secret embedded in the webhook URL you register with Garmin, e.g. register
# https://yourdomain/webhooks/garmin?token=THIS_VALUE
# Generate: py -c "import secrets; print(secrets.token_urlsafe(24))"
GARMIN_WEBHOOK_TOKEN=
